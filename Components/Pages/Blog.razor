@page "/blog"
@page "/blog/{fileName}"
@using System.Globalization
@using BlazorStatic
@using BlazorStatic.Services
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService

@if (string.IsNullOrWhiteSpace(FileName))
{
    <div>
        <div class="py-10 mb-2">
            <p class="text-[11px] uppercase tracking-widest text-sky-400 font-mono mb-3">Writing</p>
            <H1>Blog</H1>
            <p class="mt-3 text-sm text-slate-500 font-sans">Thoughts, projects, and various exploits in tech.</p>
        </div>
        <PostsList />
    </div>
    return;
}

@if (post == null)
{
    <div class="py-20 text-center">
        <p class="text-slate-500 font-mono text-sm">Post not found.</p>
        <a class="mt-6 inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-sky-400 hover:text-sky-300 font-sans transition-colors" href="blog">
            ← Back to blog
        </a>
    </div>
    return;
}

<article class="py-10">
    <header class="mb-10 pb-8 border-b border-white/[0.06]">
        <div class="flex items-center gap-3 mb-5">
            @if (post.FrontMatter.Tags != null)
            {
                @foreach (var tag in post.FrontMatter.Tags.Take(3))
                {
                    <span class="text-[10px] font-mono uppercase tracking-wider text-sky-400 bg-sky-500/10 border border-sky-500/20 px-2 py-0.5 rounded-sm">@tag</span>
                }
            }
        </div>
        <H1>@post.FrontMatter.Title</H1>
        <div class="mt-4">
            <DateRow Published="post.FrontMatter.Published" Updated="post.FrontMatter.Updated" />
        </div>
    </header>

    <div class="xl:grid xl:grid-cols-4 xl:gap-x-10">
        <div class="xl:col-span-3">
            <div class="prose prose-invert prose-sm sm:prose-base max-w-none
                        prose-headings:font-sans prose-headings:font-semibold prose-headings:tracking-tight
                        prose-a:text-sky-400 prose-a:no-underline hover:prose-a:text-sky-300
                        prose-code:text-sky-300 prose-code:bg-sky-500/10 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
                        prose-pre:bg-slate-900 prose-pre:border prose-pre:border-white/[0.08]
                        prose-blockquote:border-sky-500/40 prose-blockquote:text-slate-400
                        prose-hr:border-white/[0.06]">
                @((MarkupString)post.HtmlContent)
            </div>
            <div class="mt-10 pt-6 border-t border-white/[0.06]">
                <a target="_blank" rel="noopener noreferrer"
                   href="@($"{WebsiteKeys.BlogPostStorageAddress}/{FileName}")"
                   class="text-[11px] uppercase tracking-widest text-slate-500 hover:text-sky-400 font-mono transition-colors">
                    View source on GitHub →
                </a>
            </div>
        </div>

        <aside class="mt-10 xl:mt-0 xl:col-start-4 xl:row-start-1">
            <div class="xl:sticky xl:top-8 space-y-8">
                <div>
                    <p class="text-[10px] uppercase tracking-widest text-slate-600 font-mono mb-3">Tags</p>
                    <TagsComponent Tags="post.FrontMatter.Tags" />
                </div>
                <div>
                    <a class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-sky-400 hover:text-sky-300 font-sans transition-colors" href="blog">
                        ← Back to blog
                    </a>
                </div>
            </div>
        </aside>
    </div>
</article>

@code {
    [Parameter] public string? FileName { get; set; }
    Post<BlogFrontMatter>? post;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(FileName)) return;
        post = blazorStaticContentService.Posts.FirstOrDefault(x => x.Url == FileName);
    }
}