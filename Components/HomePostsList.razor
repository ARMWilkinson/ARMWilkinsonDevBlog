@using System.Globalization
@using BlazorStatic
@using BlazorStatic.Services
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService
@inject BlazorStaticService blazorStaticService

<ul class="divide-y divide-white/[0.06]">
    @foreach (var (post, index) in posts.OrderByDescending(x => x.FrontMatter.Published).Select((p, i) => (p, i)))
    {
        <li class="py-7 @(index == 0 ? "pt-0" : "")">
            <article class="@(index == 0 ? "p-5 rounded-lg bg-sky-500/[0.04] border border-sky-500/[0.12]" : "")">
                <div class="flex items-center gap-3 mb-3">
                    @if (post.FrontMatter.Tags != null)
                    {
                        @foreach (var tag in post.FrontMatter.Tags.Take(2))
                        {
                            <span class="text-[10px] font-mono uppercase tracking-wider text-sky-400 bg-sky-500/10 border border-sky-500/20 px-2 py-0.5 rounded-sm">@tag</span>
                        }
                    }
                    <time class="text-xs text-slate-500 font-sans ml-auto"
                          datetime="@post.FrontMatter.Published.ToString("yyyy-MM-dd")">
                        @post.FrontMatter.Published.ToString("d MMMM, yyyy", CultureInfo.InvariantCulture)
                    </time>
                </div>
                <h2 class="text-base font-semibold text-slate-100 leading-snug mb-2 font-sans hover:text-sky-400 transition-colors">
                    <a href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">@post.FrontMatter.Title</a>
                </h2>
                <p class="text-sm text-slate-500 leading-relaxed mb-4 max-w-prose">
                    @((MarkupString)post.FrontMatter.Lead)
                </p>
                <a class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-sky-400 hover:text-sky-300 font-sans transition-colors"
                   href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">
                    Read more <span aria-hidden="true">→</span>
                </a>
            </article>
        </li>
    }
</ul>

@code {
    List<Post<BlogFrontMatter>> posts = new();

    [Parameter] public List<Post<BlogFrontMatter>>? Posts { get; set; }

    protected override void OnInitialized()
    {
        posts = Posts != null
            ? Posts.OrderByDescending(x => x.FrontMatter.Published).Take(3).ToList()
            : blazorStaticContentService.Posts;
        base.OnInitialized();
    }
}