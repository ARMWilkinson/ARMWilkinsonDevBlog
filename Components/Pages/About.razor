@page "/about"
@using BlazorStatic

<div class="py-10">
    <div class="mb-10">
        <p class="text-[11px] uppercase tracking-widest text-sky-400 font-mono mb-3">About</p>
        <H1>Andrew Wilkinson</H1>
    </div>

    <div class="sm:grid sm:grid-cols-4 sm:gap-x-10 sm:items-start">
        <div class="sm:col-span-1 mb-8 sm:mb-0">
            <div class="space-y-3">
                <img class="w-full aspect-square object-cover rounded-lg border border-white/[0.08]"
                     src="../media/about/PhotoOfMeOne.jpg" alt="Andrew Wilkinson" />
                <div class="flex gap-2">
                    <img class="w-1/2 aspect-square object-cover rounded-md border border-white/[0.08]"
                         src="../media/about/PhotoOfMeTwo.jpg" alt="" />
                    <img class="w-1/2 aspect-square object-cover rounded-md border border-white/[0.08]"
                         src="../media/about/PhotoOfMeThree.jpg" alt="" />
                </div>
            </div>

            <!-- Contact / links -->
            <div class="mt-6 space-y-2.5">
                <p class="text-[10px] uppercase tracking-widest text-slate-600 font-mono mb-3">Contact</p>

                <a href="mailto:andrew@armwilkinson.dev"
                   class="flex items-center gap-2.5 text-sm text-slate-400 hover:text-sky-400 transition-colors duration-200 group">
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-sky-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                    <span class="font-mono text-xs">email</span>
                </a>

                <a href="https://www.linkedin.com/in/andrew-wilkinson-b06230121/" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-2.5 text-sm text-slate-400 hover:text-sky-400 transition-colors duration-200 group">
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-sky-400 transition-colors shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    <span class="font-mono text-xs">linkedin</span>
                </a>

                <a href="https://github.com/armwilkinson" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-2.5 text-sm text-slate-400 hover:text-sky-400 transition-colors duration-200 group">
                    <svg class="w-4 h-4 text-slate-600 group-hover:text-sky-400 transition-colors shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                    <span class="font-mono text-xs">github</span>
                </a>
            </div>
        </div>

        <div class="sm:col-span-3 space-y-6">
            <p class="text-sm text-slate-300 leading-relaxed">
                Hi, I'm Andrew — a full-stack software developer based in Sheffield, writing about code, computing, and the various rabbit holes that come with the territory.
            </p>
            <p class="text-sm text-slate-400 leading-relaxed">
                I work primarily in .NET/C#, React, TypeScript, and Next.js. This blog is where I document projects, share things I've learned, and think out loud about software development.
            </p>
            <div class="pt-4 border-t border-white/[0.06]">
                <p class="text-[10px] uppercase tracking-widest text-slate-600 font-mono mb-3">Currently</p>
                <ul class="space-y-2 text-sm text-slate-400">
                    <li class="flex items-start gap-2">
                        <span class="text-sky-500 mt-0.5" aria-hidden="true">→</span>
                        Building <a class="text-sky-400 hover:text-sky-300 transition-colors" href="https://actreel.co.uk" target="_blank" rel="noopener noreferrer">Act Reel</a>, a social platform for the amateur theatre community
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-sky-500 mt-0.5" aria-hidden="true">→</span>
                        Open to mid-level full-stack roles in the North of England
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>