@using BlazorStatic
@using BlazorStatic.Services
@using System.Net
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService

<div class="flex flex-wrap gap-2 @ClassPlus">
    @foreach (var tag in Tags)
    {
        <a class="text-[10px] font-mono uppercase tracking-wider text-sky-400 bg-sky-500/10 border border-sky-500/20 px-2 py-0.5 rounded-sm hover:bg-sky-500/20 hover:border-sky-500/40 transition-colors duration-200"
           href="@blazorStaticContentService.Options.Tags.TagsPageUrl/@WebUtility.UrlEncode(tag)">
            @tag
        </a>
    }
</div>

@code {
    [Parameter] public List<string> Tags { get; set; } = [];
    [Parameter] public string ClassPlus { get; set; } = "";
}