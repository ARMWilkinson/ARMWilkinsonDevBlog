@inject NavigationManager Nm

<header class="flex items-center justify-between py-8 border-b border-white/[0.06]">
    <div>
        <a href="" class="group flex items-center gap-2">
            <span class="text-white font-mono text-sm font-semibold tracking-tight group-hover:text-sky-400 transition-colors duration-200">ARMWilkinson</span>
            <span class="text-sky-500/60 font-mono text-xs">.dev</span>
        </a>
    </div>
    <nav class="hidden sm:flex items-center gap-8">
        @foreach (var item in menuItems)
        {
            <NavLink ActiveClass="text-sky-400"
                     class="text-[11px] uppercase tracking-widest text-slate-400 hover:text-white transition-colors duration-200 font-sans"
                     Match="@(item.Link == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                     href="@item.Link">
                @item.Name
            </NavLink>
        }
    </nav>
    <button id="toggle-button" aria-label="Toggle Menu" class="sm:hidden text-slate-400 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-6 w-6">
            <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
        </svg>
    </button>
    <div id="mobile-menu" class="fixed left-0 top-0 z-10 h-full w-full translate-x-full transform duration-300 ease-in-out bg-gray-950/[0.98]">
        <div class="flex justify-end">
            <button id="close-mobile-menu-button" class="mr-8 mt-10 h-8 w-8 text-slate-400" aria-label="Toggle Menu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
        <nav class="mt-16 px-10">
            @foreach (var item in menuItems)
            {
                <div class="py-4 border-b border-white/[0.06]">
                    <NavLink ActiveClass="text-sky-400" class="text-xl font-mono text-slate-300 hover:text-white transition-colors"
                             Match="@(item.Link == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)" href="@item.Link">
                        @item.Name
                    </NavLink>
                </div>
            }
        </nav>
    </div>
</header>

<script>
    const toggleMobileMenu = () => document.querySelector('#mobile-menu').classList.toggle('translate-x-full');
    document.querySelector('#toggle-button').addEventListener('click', toggleMobileMenu);
    document.querySelector('#close-mobile-menu-button').addEventListener('click', toggleMobileMenu);
</script>

@code {
    List<MenuItem> menuItems =
    [
        new("About", "about"),
        new("Blog", "blog"),
        new("Projects", "projects"),
        new("Library", "library")
    ];

    record MenuItem(string Name, string Link);
}