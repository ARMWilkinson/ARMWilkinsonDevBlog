@using System.Globalization
@using BlazorStatic
@using BlazorStatic.Services
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService
@inject BlazorStaticService blazorStaticService

<ul class="divide-y divide-white/[0.06]">
    @foreach (var post in posts.OrderByDescending(x => x.FrontMatter.Published))
    {
        <li class="py-7">
            <article class="sm:grid sm:grid-cols-4 sm:gap-x-8 sm:items-start">
                <div class="mb-3 sm:mb-0">
                    <DateRow Published="post.FrontMatter.Published" Updated="post.FrontMatter.Updated" />
                </div>
                <div class="sm:col-span-3 space-y-3">
                    <div class="flex flex-wrap gap-2">
                        @if (post.FrontMatter.Tags != null)
                        {
                            @foreach (var tag in post.FrontMatter.Tags.Take(3))
                            {
                                <span class="text-[10px] font-mono uppercase tracking-wider text-sky-400 bg-sky-500/10 border border-sky-500/20 px-2 py-0.5 rounded-sm">@tag</span>
                            }
                        }
                    </div>
                    <h2 class="text-base font-semibold text-slate-100 leading-snug font-sans">
                        <a class="hover:text-sky-400 transition-colors duration-200"
                           href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">
                            @post.FrontMatter.Title
                        </a>
                    </h2>
                    <p class="text-sm text-slate-500 leading-relaxed">
                        @((MarkupString)post.FrontMatter.Lead)
                    </p>
                    <a class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-sky-400 hover:text-sky-300 font-sans transition-colors"
                       href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">
                        Read more <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>
        </li>
    }
</ul>

@code {
    List<Post<BlogFrontMatter>> posts = new();

    [Parameter] public List<Post<BlogFrontMatter>>? Posts { get; set; }

    protected override void OnInitialized()
    {
        posts = Posts != null
            ? Posts.OrderByDescending(x => x.FrontMatter.Published).ToList()
            : blazorStaticContentService.Posts;
        base.OnInitialized();
    }
}